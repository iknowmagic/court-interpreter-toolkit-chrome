{
	"manifest_version": 3,
	"name": "Court Interpreter Toolkit",
	"description": "Practice tool for court interpreters with timed sessions, vocabulary drills, and task management.",
	"action": {
		"default_popup": "src/pages/popup/index.html",
		"default_icon": {
			"32": "icon.png"
		}
	},
	"chrome_url_overrides": {
		"newtab": "src/pages/newtab/index.html"
	},
	"icons": {
		"128": "icon.png"
	},
	"permissions": ["activeTab", "alarms", "contextMenus"],
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*", "<all_urls>"],
			"js": ["src/pages/content/index.tsx"],
			"css": ["contentStyle.css"]
		}
	],
	"devtools_page": "src/pages/devtools/index.html",
	"web_accessible_resources": [
		{
			"resources": ["contentStyle.css", "icon.png"],
			"matches": []
		}
	]
}
