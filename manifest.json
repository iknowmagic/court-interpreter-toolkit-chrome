{
	"manifest_version": 3,
	"name": "Court Interpreter Toolkit",
	"description": "Practice tool for court interpreters with timed sessions, vocabulary drills, and task management.",
	"action": {
		"default_popup": "src/pages/popup/index.html",
		"default_icon": {
			"16": "icon-16.png",
			"32": "icon-32.png",
			"48": "icon-48.png",
			"128": "icon-128.png"
		}
	},
	"icons": {
		"16": "icon-16.png",
		"32": "icon-32.png",
		"48": "icon-48.png",
		"128": "icon-128.png"
	},
	"permissions": ["alarms", "contextMenus", "storage"]
}
